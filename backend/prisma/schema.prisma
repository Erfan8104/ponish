    generator client {
      provider = "prisma-client-js"
    }

    datasource db {
      provider = "postgresql"
      url      = env("DATABASE_URL")
    }
model User {
  id               Int       @id @default(autoincrement())
  phone            String    @unique
  isVerified       Boolean   @default(false)
  profileCompleted Boolean   @default(false)

  // اطلاعات عمومی
  name             String?
  email            String?
  avatar           String?
  role             UserRole?

  // employer
  province         String?
  city             String?
  company          String?

  // freelancer
  birthDate        String?
  birthPlace       String?
  freelancerProvince String?
  freelancerCity   String?
  education        String?
  skills           String?
  experience       String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  projects         Project[]
}

enum UserRole {
  employer
  freelancer
}


  model Project {
    id                  Int      @id @default(autoincrement())
    title               String
    category            String
    description         String?
    province            String
    city                String
    address             String?
    
    // مرحله ۲: اطلاعات جغرافیایی
    areaSelectionMethod String   @default("map")
    polygonCoordinates  Json?    
    geoJson             Json?    
    calculatedArea      Float    @default(0.0)
    coordinateSystem    String   @default("WGS84")
    utmZone             String?

    // مرحله ۳: مشخصات فنی
    techType            String[] 
    outputFormats       String[] 
    requiredAccuracy    String   @default("1-5cm")

    // مرحله ۴: زمان و بودجه
    deliveryTime        String   @default("1-week")
    budgetType          String   @default("custom")
    minBudget           String?
    maxBudget           String?

    // --- اضافه کردن رابطه به کاربر لاگین شده ---
    userId              Int      // شناسه کاربری که پروژه را ساخته
    user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt
  }

  // مدل OTP بدون تغییر باقی می‌ماند
  model OTP {
    id        Int      @id @default(autoincrement())
    phone     String
    code      String
    expiresAt DateTime
    createdAt DateTime @default(now())
  }